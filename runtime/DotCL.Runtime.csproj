<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <PackageId>DotCL.Runtime</PackageId>
    <Version>0.1.6</Version>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    <Description>Common Lisp on .NET — embeddable runtime library</Description>
    <Authors>SANO Masatoshi</Authors>
    <Copyright>Copyright © 2026 SANO Masatoshi</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/dotcl/dotcl</PackageProjectUrl>
    <RepositoryUrl>https://github.com/dotcl/dotcl.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>lisp;common-lisp;dotnet;embeddable</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <RuntimeIdentifiers>win-x64;win-arm64;linux-x64;linux-arm64;osx-x64;osx-arm64;android-arm64;android-x64;any</RuntimeIdentifiers>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
    <!-- dotcl.core bundled as a content file so consuming projects get it
         copied to their output directory automatically (FindCore picks it up
         via AppContext.BaseDirectory). Generated by `make compile-core-fasl`
         or `make pack` before dotnet pack is invoked. -->
    <None Include="dotcl.core" Condition="Exists('dotcl.core')">
      <Pack>true</Pack>
      <PackagePath>contentFiles/any/any/</PackagePath>
    </None>
    <Content Include="dotcl.core" Condition="Exists('dotcl.core')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- Exclude Program.cs — entry point lives in the dotcl tool project -->
  <ItemGroup>
    <Compile Remove="Program.cs" />
  </ItemGroup>

  <!-- Windows-only sources excluded for non-Windows RID builds -->
  <PropertyGroup Condition="$(RuntimeIdentifier.StartsWith('android')) Or $(RuntimeIdentifier.StartsWith('linux')) Or $(RuntimeIdentifier.StartsWith('osx')) Or '$(OS)' != 'Windows_NT'">
    <DefineConstants>$(DefineConstants);DOTCL_NO_WINFORMS</DefineConstants>
  </PropertyGroup>
  <ItemGroup Condition="$(RuntimeIdentifier.StartsWith('android')) Or $(RuntimeIdentifier.StartsWith('linux')) Or $(RuntimeIdentifier.StartsWith('osx')) Or '$(OS)' != 'Windows_NT'">
    <Compile Remove="Runtime.WinForms.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../runtime.docgen/runtime.docgen.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <Target Name="SetGitCommitVersion" BeforeTargets="GetAssemblyVersion;BeforeBuild">
    <Exec Command="git describe --tags --long --abbrev=7 --dirty --match v*"
          ConsoleToMsBuild="true"
          IgnoreExitCode="true">
      <Output TaskParameter="ConsoleOutput" PropertyName="_GitDesc" />
    </Exec>
    <Exec Command="git rev-parse --short=7 HEAD"
          ConsoleToMsBuild="true"
          IgnoreExitCode="true"
          Condition="'$(_GitDesc)' == '' Or !$(_GitDesc.StartsWith('v'))">
      <Output TaskParameter="ConsoleOutput" PropertyName="_GitFallbackSha" />
    </Exec>
    <PropertyGroup>
      <_GitFallbackSha Condition="'$(_GitFallbackSha)' == ''">unknown</_GitFallbackSha>
      <_GitDesc Condition="'$(_GitDesc)' == '' Or !$(_GitDesc.StartsWith('v'))">v0.0.0-0-g$(_GitFallbackSha)</_GitDesc>
      <_DescNoV>$(_GitDesc.Substring(1))</_DescNoV>
      <_HasDirty Condition="$(_DescNoV.EndsWith('-dirty'))">true</_HasDirty>
      <_HasDirty Condition="!$(_DescNoV.EndsWith('-dirty'))">false</_HasDirty>
      <_DescNoDirty Condition="'$(_HasDirty)' == 'true'">$(_DescNoV.Substring(0, $([MSBuild]::Subtract($(_DescNoV.Length), 6))))</_DescNoDirty>
      <_DescNoDirty Condition="'$(_HasDirty)' == 'false'">$(_DescNoV)</_DescNoDirty>
      <_LastDashG>$(_DescNoDirty.LastIndexOf('-g'))</_LastDashG>
      <_Sha>$(_DescNoDirty.Substring($([MSBuild]::Add($(_LastDashG), 2))))</_Sha>
      <_BeforeSha>$(_DescNoDirty.Substring(0, $(_LastDashG)))</_BeforeSha>
      <_LastDash>$(_BeforeSha.LastIndexOf('-'))</_LastDash>
      <_Count>$(_BeforeSha.Substring($([MSBuild]::Add($(_LastDash), 1))))</_Count>
      <_Tag>$(_BeforeSha.Substring(0, $(_LastDash)))</_Tag>
      <_DirtySuffix Condition="'$(_HasDirty)' == 'true'">.dirty</_DirtySuffix>
      <_DirtySuffix Condition="'$(_HasDirty)' == 'false'"></_DirtySuffix>
      <InformationalVersion Condition="'$(_Count)' == '0' And '$(_HasDirty)' == 'false'">$(_Tag)</InformationalVersion>
      <InformationalVersion Condition="'$(_Count)' != '0' Or '$(_HasDirty)' == 'true'">$(_Tag)+$(_Count).g$(_Sha)$(_DirtySuffix)</InformationalVersion>
    </PropertyGroup>
  </Target>

</Project>
