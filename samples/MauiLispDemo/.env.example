# MauiLispDemo task runner — per-machine config.
# Copy this file to .env and adjust paths for your environment.
# .env is gitignored.

# --- Java SDK (required for MAUI Android build) ---
# Default: Android Studio bundled JBR.
# JAVA_HOME=C:\Program Files\Android\Android Studio\jbr

# --- Android SDK ---
# Default: %LOCALAPPDATA%\Android\Sdk
# ANDROID_SDK_ROOT=C:\Users\you\AppData\Local\Android\Sdk

# --- Target framework versions (rarely overridden) ---
# WINDOWS_TFM=net10.0-windows10.0.19041.0
# ANDROID_TFM=net10.0-android

# --- scrcpy launch flags (tune for your CPU/USB) ---
# Snapdragon Windows ARM64 だと 800x ... くらいが安定。
# x64 PC なら 1920x や --max-fps=60 も OK。
# SCRCPY_FLAGS=--max-size=800 --max-fps=15 --video-bit-rate=2M --no-audio

# --- adb logcat フィルタ ---
# 既定: MauiLispDemo の v 以上 + 全 tag の e 以上
# LOGCAT_FILTER=MauiLispDemo:V *:E
